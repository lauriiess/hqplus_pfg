# ── HealthQueue+ Server Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/healthqueue

# JWT secret — keep this secret!
JWT_SECRET=hqplus_secret_2024

# Server port
PORT=4000

# Node environment (development | production)
NODE_ENV=development

# Optional: comma-separated allowed CORS origins
# Leave blank to allow all origins (safe for local dev)
# FRONTEND_ORIGINS=http://localhost:3000,http://192.168.1.x:3000

# Optional: Rasa chatbot server URL (leave blank to use FAQ fallback)
# RASA_SERVER_URL=http://localhost:5005
