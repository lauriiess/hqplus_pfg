# ──────────────────────────────────────────────
#  HealthQueue+ Server — Environment Variables
#  Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/healthqueue

# JWT secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# JWT expiry (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Port for the server
PORT=4000

# Comma-separated allowed frontend origins (browser CORS)
# Use * for development only — NEVER in production
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Semaphore SMS OTP (https://semaphore.co)
# Sign up and get your API key from the dashboard
SEMAPHORE_API_KEY=your_semaphore_api_key_here
SEMAPHORE_SENDER_NAME=HEALTHQ

# OpenAI for AI-assisted insights (optional)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Rasa chatbot server URL (self-hosted)
RASA_SERVER_URL=http://localhost:5005

# Google Maps Geocoding API key (for clinic geolocation)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# App environment
NODE_ENV=development
