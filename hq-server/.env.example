# HealthQueue+ Server — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Database ──────────────────────────────────────────────────────
# MongoDB Atlas connection string (required)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/hqplus?retryWrites=true&w=majority

# ── Security ──────────────────────────────────────────────────────
# JWT signing secret — use a long random string (required)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Chatbot (optional) ────────────────────────────────────────────
# If not set, the server uses the local MongoDB FAQ database
# RASA_SERVER_URL=http://localhost:5005
